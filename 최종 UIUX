            gaps: ['학술적 에세이 작성 경험 부족', 'ODA 정책 심화 지식 부족', '통계/데이터 활용 능력 미흡', '공모전 수상 이력 없음'],
            timeline: [
                { date: '5/16 ~ 5/20 (5일)', task: 'ODA 정책 심화 리서치', sub: 'KOICA 연간보고서, ODA 통계 분석, 주요 정책 이슈 정리', future: false },
                { date: '5/21 ~ 5/25 (5일)', task: '에세이 주제 선정 & 개요 작성', sub: '차별화된 주제 3개 후보 → 1개 확정, 논리 구조 설계', future: false },
                { date: '5/26 ~ 5/31 (6일)', task: '에세이 초고 작성', sub: '3000자 기준 초고 완성, 데이터/사례 인용 포함', future: true },
                { date: '6/1 ~ 6/7 (7일)', task: '수정 & 피드백 반영', sub: '교수/선배 피드백, 논리 보강, 문장 다듬기', future: true },
                { date: '6/8 ~ 6/13 (6일)', task: '최종 교정 & 제출', sub: '맞춤법 검사, 형식 점검, 마감 2일 전 제출', future: true }
            ],
            calendarTasks: {
                16: 'ODA 보고서', 17: '통계 분석', 18: '정책 이슈', 19: '사례 조사', 20: '리서치 정리',
                21: '주제 후보①', 22: '주제 후보②', 23: '주제 확정', 24: '개요 작성', 25: '구조 설계',
                26: '초고 시작', 27: '본론 작성', 28: '사례 삽입', 29: '결론 작성', 30: '초고 완성', 31: '자체 검토'
            }
        }
    };

    // Personal schedule (user's own events)
    const personalSchedule = {
        16: '집 대청소',
        18: '동기 모임 (저녁)',
        20: '헬스장 PT',
        22: '도서관 스터디',
        24: '친구 생일',
        25: '헬스장 PT',
        27: '가족 저녁',
        29: '헬스장 PT',
        31: '영화 약속'
    };

    let currentProgram = 'koica';
    let currentView = 'action';

    function switchProgram(key) {
        currentProgram = key;
        renderGap();
        renderActionView();
        renderCalendarView();
    }

    function switchView(view) {
        currentView = view;
        document.getElementById('actionView').style.display = view === 'action' ? 'block' : 'none';
        document.getElementById('calendarView').style.display = view === 'calendar' ? 'block' : 'none';
        document.getElementById('btnAction').classList.toggle('active', view === 'action');
        document.getElementById('btnCalendar').classList.toggle('active', view === 'calendar');
    }

    function renderGap() {
        const p = programs[currentProgram];
        document.getElementById('gapArea').innerHTML = `
            <div class="gap-grid">
                <div class="gap-card has-skill">
                    <h4>✅ 보유 역량 (강점)</h4>
                    <ul>${p.strengths.map(s => `<li>${s}</li>`).join('')}</ul>
                </div>
                <div class="gap-card needs-skill">
                    <h4>⚠️ 보완 필요 (Gap)</h4>
                    <ul>${p.gaps.map(g => `<li>${g}</li>`).join('')}</ul>
                </div>
            </div>
        `;
    }

    function renderActionView() {
        const p = programs[currentProgram];
        let html = `<h3 style="font-size:0.9rem;font-weight:700;margin-bottom:1rem;color:var(--navy);">
            🗓️ AI 수립 액션 플랜 (D-${p.dday} 마감 기준)
        </h3><div class="timeline">`;
        p.timeline.forEach(item => {
            html += `<div class="timeline-item ${item.future ? 'future' : ''}">
                <div class="timeline-date">${item.date}</div>
                <div class="timeline-content">${item.task}</div>
                <div class="timeline-sub">${item.sub}</div>
            </div>`;
        });
        html += `</div>
        <div style="margin-top:1.2rem;padding:0.8rem;background:linear-gradient(135deg,#ecfdf5,#f0f4ff);border-radius:8px;font-size:0.8rem;border:1px solid var(--green);">
            🤖 <strong>에이전트 메모:</strong> 이 플랜은 마감일(${p.deadline}) 기준 역산하여 자동 수립되었습니다. 매일 오전 9시에 당일 할 일을 리마인드해 드리겠습니다.
        </div>`;
        document.getElementById('actionView').innerHTML = html;
    }

    function renderCalendarView() {
        const p = programs[currentProgram];
        const year = 2026, month = 5;
        const firstDay = new Date(year, month - 1, 1).getDay();
        const daysInMonth = new Date(year, month, 0).getDate();

        let html = `<div class="calendar-header-row">
            <h3 style="font-size:0.9rem;font-weight:700;color:var(--navy);margin-bottom:0.3rem;">📅 2026년 5월 월간 스케줄</h3>
            <div style="display:flex;gap:1.2rem;font-size:0.7rem;margin-bottom:0.8rem;color:var(--text-light);align-items:center;">
                <span style="display:flex;align-items:center;gap:0.3rem;"><span style="display:inline-block;width:20px;height:4px;background:linear-gradient(90deg,var(--navy),var(--navy-light));border-radius:2px;"></span> 신청기간</span>
                <span>· 준비 할 일</span>
                <span style="color:#92400e;">★ 개인 일정</span>
            </div>
        </div>`;
        html += `<div class="calendar-grid">`;
        const dayNames = ['일','월','화','수','목','금','토'];
        dayNames.forEach(d => { html += `<div class="cal-day-name">${d}</div>`; });

        for (let i = 0; i < firstDay; i++) { html += `<div class="cal-cell empty"></div>`; }

        for (let day = 1; day <= daysInMonth; day++) {
            const agentTask = p.calendarTasks[day] || '';
            const personalTask = personalSchedule[day] || '';
            const isToday = day === 16;

            let barHtml = '';
            if (day >= p.applyStart && day <= p.applyEnd) {
                let barClass = 'middle';
                if (day === p.applyStart) barClass = 'start';
                else if (day === p.applyEnd) barClass = 'end';
                if (p.applyStart === p.applyEnd) barClass = 'single';
                barHtml = `<div class="cal-period-bar ${barClass}"></div>`;
                if (day === p.applyStart) {
                    barHtml = `<div class="cal-period-label">신청▸</div>` + barHtml;
                }
            }

            html += `<div class="cal-cell ${isToday ? 'today' : ''}">
                <div class="cal-date">${day}</div>
                ${barHtml}
                ${agentTask ? `<div class="cal-task-text">· ${agentTask}</div>` : ''}
                ${personalTask ? `<div class="cal-personal-text">★ ${personalTask}</div>` : ''}
            </div>`;
        }
        html += `</div>`;
        html += `<div style="margin-top:0.8rem;padding:0.6rem;background:#f9fafb;border-radius:8px;font-size:0.75rem;color:var(--text-light);">
            💡 개인 일정은 직접 추가/수정할 수 있습니다. 에이전트가 일정 충돌 시 자동으로 플랜을 조정합니다.
        </div>`;
        document.getElementById('calendarView').innerHTML = html;
    }

    // Feedback system
    function toggleFb(btn, type) {
        var row = btn.parentElement;
        var buttons = row.querySelectorAll('.fb-btn');
        buttons.forEach(function(b) { b.classList.remove('like-active', 'dislike-active'); });
        btn.classList.add(type === 'like' ? 'like-active' : 'dislike-active');

        var toast = document.getElementById('feedbackToast');
        var name = btn.closest('.fb-program').querySelector('.fb-program-name').textContent;
        if (type === 'like') {
            toast.textContent = '👍 "' + name + '" 관심 표시 완료!';
        } else {
            toast.textContent = '👎 "' + name + '" 관심 없음 반영!';
        }
        toast.classList.add('show');
        setTimeout(function() { toast.classList.remove('show'); }, 2000);
    }

    function submitFeedback() {
        var text = document.getElementById('fbText').value.trim();
        var toast = document.getElementById('feedbackToast');
        if (text) {
            toast.textContent = '✅ 피드백이 에이전트에 반영되었습니다. 다음 추천부터 적용됩니다!';
        } else {
            toast.textContent = '✅ 관심 표시가 저장되었습니다!';
        }
        toast.classList.add('show');
        document.getElementById('fbText').value = '';
        setTimeout(function() { toast.classList.remove('show'); }, 2500);
    }

    // Settings Modal
    function openSettings() {
        document.getElementById('settingsModal').classList.add('show');
    }
    function closeSettings() {
        document.getElementById('settingsModal').classList.remove('show');
    }
    function saveSettings() {
        const name = document.getElementById('setName').value;
        const major = document.getElementById('setMajor').value;
        const year = document.getElementById('setYear').value;
        const interests = document.getElementById('setInterests').value;
        const activityType = document.getElementById('setActivityType').value;
        const language = document.getElementById('setLanguage').value;
        const status = document.getElementById('setStatus').value;
        const hours = document.getElementById('setHours').value;

        document.querySelector('.profile-name').textContent = name;
        document.querySelector('.profile-avatar').textContent = name.charAt(0);
        document.querySelector('.profile-sub').textContent = major + ' · ' + year + '학년';

        const tagsContainer = document.querySelector('.profile-tags');
        const tagColors = ['tag-blue', 'tag-green', 'tag-orange', 'tag-blue'];
        const interestArr = interests.split(',').map(function(s){ return s.trim(); }).filter(function(s){ return s; });
        tagsContainer.innerHTML = interestArr.map(function(t, i) {
            return '<span class="tag ' + tagColors[i % tagColors.length] + '">' + t + '</span>';
        }).join('');

        const statusItems = document.querySelectorAll('.status-item');
        statusItems[0].querySelector('.status-value').innerHTML = '● ' + status;
        statusItems[1].querySelector('.status-value').textContent = hours;
        statusItems[2].querySelector('.status-value').textContent = interests.split(',').slice(0,2).join(' / ');
        statusItems[3].querySelector('.status-value').textContent = activityType;
        statusItems[4].querySelector('.status-value').textContent = language;

        closeSettings();
    }
    document.getElementById('settingsModal').addEventListener('click', function(e) {
        if (e.target === this) closeSettings();
    });

    // Initialize
    switchProgram('koica');
    </script>
</body>
</html>
